# Copy this file to .env and fill in your key. .env is gitignored.

# Pneumatic public API key for the target instance (Settings -> API in Pneumatic).
PNEUMATIC_API_KEY=your-api-key-here

# Optional: override the API base URL.
# Self-hosted instances serve the API on the subdomain at port 8001 over https.
# Defaults to the yamaha-stage-2 endpoint if unset.
# PNEUMATIC_BASE_URL=https://yamaha-stage-2.pneumatic.app:8001
